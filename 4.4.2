x = float(input("Введите координату x: "))
y = float(input("Введите координату y: "))

# Здесь нужно записать условия для областей согласно рисунку
# Пример для областей: I — первая четверть, II — третья четверть
if x > 0 and y > 0:
    print("Точка попадает в область I")
elif x < 0 and y < 0:
    print("Точка попадает в область II")
else:
    print("Точка не попадает в указанные области (или попадает на границу)")