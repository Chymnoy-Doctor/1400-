# Ввод данных
kmh = float(input("Введите скорость в километрах в час: "))
ms = float(input("Введите скорость в метрах в секунду: "))

# Перевод м/с в км/ч (1 м/с = 3.6 км/ч)
ms_in_kmh = ms * 3.6

# Сравнение скоростей
if kmh > ms_in_kmh:
    print(f"Скорость {kmh} км/ч больше")
elif kmh < ms_in_kmh:
    print(f"Скорость {ms} м/с больше")
else:
    print("Скорости равны")