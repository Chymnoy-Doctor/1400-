# Ввод данных
km = float(input("Введите расстояние в километрах: "))
ft = float(input("Введите расстояние в футах: "))

# Перевод футов в километры (1 фут = 0.3048 м = 0.0003048 км)
ft_in_km = ft * 0.0003048

# Сравнение расстояний
if km < ft_in_km:
    print(f"Расстояние в {km} км меньше")
elif km > ft_in_km:
    print(f"Расстояние в {ft} футов меньше")
else:
    print("Расстояния равны")